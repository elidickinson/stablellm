# Listening
HOST=0.0.0.0
PORT=4000

# Optional: require this key from clients connecting to the proxy
# API_KEY=my-proxy-secret

# Endpoints in priority order.
# Format: ENDPOINT_<N>=<base_url>|<api_key>|<model_override>
# model_override is optional — omit to pass through the client's requested model.
ENDPOINT_1=https://api.openai.com/v1|sk-your-key-here|
ENDPOINT_2=https://api.openai.com/v1|sk-backup-key-here|
ENDPOINT_3=https://openrouter.ai/api/v1|sk-or-xxx|openai/gpt-4o

# Model groups: route a virtual model name to specific endpoints.
# Format: GROUP_<NAME>=<comma-separated ENDPOINT_N numbers>
# Request model "cheap" → tries ENDPOINT_2 then ENDPOINT_3 in order.
# Use "cheap:fastest" to race them.
# GROUP_CHEAP=2,3

# Retry behavior
COOLOFF_SECONDS=30
REQUEST_TIMEOUT=120
CONNECT_TIMEOUT=4
