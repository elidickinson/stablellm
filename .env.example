# Listening
HOST=0.0.0.0
PORT=4000

# Optional: require this key from clients connecting to the proxy
# API_KEY=my-proxy-secret

# Endpoints in priority order.
# Format: ENDPOINT_<NAME>=<base_url>|<api_key>|<model_override>
# model_override is optional — omit to pass through the client's requested model.
ENDPOINT_OPENAI=https://api.openai.com/v1|sk-your-key-here|
ENDPOINT_OPENAI_BACKUP=https://api.openai.com/v1|sk-backup-key-here|
ENDPOINT_OPENROUTER=https://openrouter.ai/api/v1|sk-or-xxx|openai/gpt-4o

# Model groups: route a virtual model name to specific endpoints.
# Format: GROUP_<NAME>=<comma-separated endpoint names>
# Request model "cheap" → tries ENDPOINT_OPENAI_BACKUP then ENDPOINT_OPENROUTER in order.
# Use "cheap:fastest" to race them.
# GROUP_CHEAP=openai_backup,openrouter

# GROUP_DEFAULT controls which endpoints (and order) are used when the model
# doesn't match any named group. If omitted, all endpoints are used in order.
# GROUP_DEFAULT=openai,openai_backup,openrouter

# Retry behavior
COOLOFF_SECONDS=30
REQUEST_TIMEOUT=120
CONNECT_TIMEOUT=4
