# Listening
HOST=0.0.0.0
PORT=4000

# Optional: require this key from clients connecting to the proxy
# API_KEY=my-proxy-secret

# Config file path (default: config.yaml)
# CONFIG_FILE=config.yaml

# API keys referenced from config.yaml via ${VAR} syntax
OPENAI_API_KEY=sk-your-key-here
# OPENAI_BACKUP_KEY=sk-backup-key-here
# CEREBRAS_API_KEY=sk-cerebras-key
# OPENROUTER_API_KEY=sk-or-xxx

# Retry behavior
COOLOFF_SECONDS=30
REQUEST_TIMEOUT=120
CONNECT_TIMEOUT=4
